PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb://localhost:27017/apexledger?replicaSet=rs0
JWT_SECRET=change-me-in-production-min-32-characters-long
JWT_EXPIRES_IN=7d

# Cloudflare R2 — required (no local disk storage)
R2_ACCOUNT_ID=
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# Access Key ID = 32 chars · Secret Access Key = 64 chars
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=your-bucket-name
# Public URL after enabling bucket public access (NOT the S3 API endpoint)
# e.g. https://pub-xxxxxxxx.r2.dev  OR  https://files.yourdomain.com
R2_PUBLIC_BASE_URL=

MAX_FILE_SIZE_MB=10
