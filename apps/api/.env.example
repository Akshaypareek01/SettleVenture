PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb://localhost:27017/apexledger
JWT_SECRET=change-me-in-production-min-32-characters-long
JWT_EXPIRES_IN=7d
# R2 — optional. Access key must be exactly 32 chars (from Cloudflare R2 API tokens).
# If missing/invalid, files save locally under apps/api/uploads/
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=apexledger
MAX_FILE_SIZE_MB=10
